# =========================
# 1) 模型与基础参数（Context 支持 env 覆盖）
# =========================
MODEL=deepseek/deepseek-chat
# 你也可以切成 openai，例如：
# MODEL=openai/gpt-4.1-mini

DEBUG=false
ENABLE_TOOLS=true
ENABLE_WEB_SEARCH=true
TIMEZONE=Asia/Shanghai

MAX_SEARCH_RESULTS=10
RECURSION_LIMIT=20
MAX_HISTORY_MESSAGES=30

# =========================
# 2) Tavily 搜索（你启用 web_search 时需要）
# =========================
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx

# =========================
# 3) 推理参数（你 utils.py 里读取这些）
# =========================
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
LLM_RETRIES=2

# =========================
# 4) OpenAI / DeepSeek / 本地 OpenAI-compatible（按需填）
# =========================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_OPENAI_API_KEY=local-key

# =========================
# 5) 对话持久化（你 run_agent_enhanced.py 演示会用到）
# =========================
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_DB_PATH=./data/agent_checkpoints.sqlite3
DEFAULT_THREAD_ID=default
