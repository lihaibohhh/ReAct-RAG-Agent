# =========================
# 1) 模型与基础参数（Context 支持 env 覆盖）
# =========================
MODEL=deepseek/deepseek-chat
# 你也可以切成 openai，例如：
# MODEL=openai/gpt-4.1-mini

DEBUG=false
ENABLE_TOOLS=true
ENABLE_WEB_SEARCH=true
TIMEZONE=Asia/Shanghai

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_key
LANGCHAIN_PROJECT=react-agent-dev

RECURSION_LIMIT=50
MAX_HISTORY_MESSAGES=30

# =========================
# 2) Tavily 搜索（你启用 web_search 时需要）
# =========================
TAVILY_API_KEY=your_search_key

# =========================
# 4) OpenAI / DeepSeek / 本地 OpenAI-compatible（按需填）
# =========================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your_llm_key

LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_OPENAI_API_KEY=local-key

# =========================
# 5) 对话持久化（你 run_agent_enhanced.py 演示会用到）
# =========================
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_DB_PATH=./data(20260206)/agent_checkpoints.sqlite3
# FIX-1: DEFAULT_THREAD_ID 不设默认值，强制调用方传入 user:{username} 格式
# DEFAULT_THREAD_ID=


CHECKPOINT_BACKEND=redis
REDIS_URL=you_url
BM25_HMAC_SECRET=my-agent-bm25-secret-2026

